# Path to Particle flat data JSON file
FLAT_DATA_PATH=sample-data/flat_data.json

# Database dialect for DDL generation: "postgres" or "bigquery"
DDL_DIALECT=postgres

# Output directory for generated DDL files
OUTPUT_DIR=ddl

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# PostgreSQL connection (for local Docker pipeline)
PG_HOST=localhost
PG_PORT=5432
PG_USER=observatory
PG_PASSWORD=observatory
PG_DATABASE=observatory

# BigQuery connection (for cloud pipeline)
# BQ_PROJECT_ID=your-gcp-project-id
# BQ_DATASET=particle_observatory

# Particle Health API (only needed when using --source api)
# PARTICLE_CLIENT_ID=your-client-id
# PARTICLE_CLIENT_SECRET=your-client-secret
# PARTICLE_SCOPE_ID=your-scope-id
# PARTICLE_BASE_URL=https://sandbox.particlehealth.com
# PARTICLE_TIMEOUT=30
# PARTICLE_MAX_RETRIES=3
# PARTICLE_PATIENT_ID=patient-id-with-completed-query
