# Particle Health sandbox (defaults are pre-configured for sandbox)
# PARTICLE_CLIENT_ID=
# PARTICLE_CLIENT_SECRET=
# PARTICLE_SCOPE=

# Retell AI — required for voice calls
RETELL_API_KEY=
RETELL_FROM_NUMBER=+1XXXXXXXXXX

# Your phone number for testing (overrides patient's phone)
DEMO_OVERRIDE_PHONE=+1XXXXXXXXXX

# Webhook URL for Retell call events (use ngrok for local dev)
WEBHOOK_URL=http://localhost:8000/api/webhooks/call-events

# Email — SMTP with console fallback
# Leave SMTP_HOST empty to use console fallback (prints email to terminal)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=care-team@example.com

# Particle Signal — ADT webhook verification
SIGNAL_WEBHOOK_SECRET=

# Database path (default: toc_workflow.db in project root)
# DB_PATH=

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173
