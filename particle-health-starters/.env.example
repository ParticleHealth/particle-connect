# Particle Health API credentials (required)
# Get these from your Particle Health dashboard
PARTICLE_CLIENT_ID=your-client-id
PARTICLE_CLIENT_SECRET=your-client-secret
PARTICLE_SCOPE_ID=projects/your-scope-id

# Base URL (optional — defaults to sandbox)
# Uncomment for production:
# PARTICLE_BASE_URL=https://api.particlehealth.com

# Request timeout in seconds (optional — defaults to 30)
# PARTICLE_TIMEOUT=30
