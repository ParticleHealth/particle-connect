# Path to Particle flat data JSON file
FLAT_DATA_PATH=sample-data/flat_data.json

# Database dialect for DDL generation: "postgres" or "bigquery"
DDL_DIALECT=postgres

# Output directory for generated DDL files
OUTPUT_DIR=ddl

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# PostgreSQL connection (for local Docker pipeline)
PG_HOST=localhost
PG_PORT=5432
PG_USER=observatory
PG_PASSWORD=observatory
PG_DATABASE=observatory
